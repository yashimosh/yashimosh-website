---
import Base from "../layouts/Base.astro";
---

<Base title="Contact &mdash; Yash" description="Get in touch for consulting engagements, speaking, or collaboration.">
  <div class="container">
    <section class="hero">
      <p class="hero-label">Contact</p>
      <h1 class="hero-headline">
        Start a conversation.<br />
        <em>Not a form.</em>
      </h1>
      <p class="hero-sub">For consulting engagements, speaking invitations, or serious collaboration. I read every message &mdash; I just do not respond to all of them.</p>
    </section>
    <section class="section">
      <span class="label">Reach me</span>
      <div class="contact-block">
        <div class="contact-line">
          <span class="contact-key">Email</span>
          <span class="contact-val"><a href="mailto:yashimosh@pm.me">yashimosh@pm.me</a></span>
        </div>
        <div class="contact-line">
          <span class="contact-key">Instagram</span>
          <span class="contact-val"><a href="https://instagram.com/yashimosh" target="_blank" rel="noopener">@yashimosh</a></span>
        </div>
        <div class="contact-line">
          <span class="contact-key">LinkedIn</span>
          <span class="contact-val"><a href="https://linkedin.com/in/yashimosh" target="_blank" rel="noopener">yashimosh</a></span>
        </div>
        <div class="contact-line">
          <span class="contact-key">X</span>
          <span class="contact-val"><a href="https://x.com/yashimosh_" target="_blank" rel="noopener">@yashimosh_</a></span>
        </div>
      </div>
    </section>
    <section class="section">
      <span class="label">Before you write</span>
      <h2>What I take on.</h2>
      <div class="bio-block">
        <p>Brand strategy and communication for organizations operating in politically complex or high-stakes environments. AI creative infrastructure and workflow architecture. Strategic positioning and narrative control. Speaking and advisory engagements at the intersection of design, technology, and political consequence.</p>
        <p>I do not take on organizations that use design to suppress, surveil, or control people. That constraint is non-negotiable.</p>
      </div>
    </section>
  </div>
</Base>
