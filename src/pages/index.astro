---
import Base from "../layouts/Base.astro";
---

<Base
  title="Yash — Creative Director & Systems Strategist"
  description="Design at the intersection of political environments, brand authority, and AI infrastructure."
  lang="en"
  slug=""
>
  <div class="container">

    <section class="hero">
      <p class="hero-label reveal">Creative Director &amp; Systems Strategist</p>
      <h1 class="hero-headline reveal reveal-delay-1">
        Design that understands<br />
        <em>the room.</em>
      </h1>
      <p class="hero-sub reveal reveal-delay-2">
        I work at the intersection of political environments, brand authority,
        and AI infrastructure. If context changes everything — and it does —
        then understanding context is the actual job.
      </p>
      <p class="hero-belief reveal reveal-delay-3">Design without political awareness is complicity.</p>
    </section>

    <section class="section">
      <span class="label reveal">What I do</span>
      <div class="pillars">
        <div class="pillar reveal reveal-delay-1">
          <p class="pillar-num">01</p>
          <h3>Brand Authority</h3>
          <p>Positioning and communication strategy for organizations operating in high-stakes, politically complex environments. Credibility is engineered, not assumed.</p>
        </div>
        <div class="pillar reveal reveal-delay-2">
          <p class="pillar-num">02</p>
          <h3>Digital Governance</h3>
          <p>Design and strategy for platforms, organizations, and systems operating inside contested digital environments — censorship, surveillance, and information warfare included.</p>
        </div>
        <div class="pillar reveal reveal-delay-3">
          <p class="pillar-num">03</p>
          <h3>AI Infrastructure</h3>
          <p>Building AI-assisted creative teams and workflows. Not automation for its own sake — structural redesign of how creative organizations produce, decide, and adapt.</p>
        </div>
        <div class="pillar reveal reveal-delay-4">
          <p class="pillar-num">04</p>
          <h3>Cognitive Engineering</h3>
          <p>Understanding how platforms, narratives, and interfaces shape behavior and belief at scale. Applied to brand, governance, and communications strategy.</p>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="constraint reveal">
        <p>
          <strong>What I do not do.</strong> I do not take on organizations
          that use design to suppress, surveil, or control people. That
          constraint is non-negotiable and pre-dates every conversation about
          scope or budget.
        </p>
      </div>
    </section>

  </div>
</Base>
