---
import Base from "../../layouts/Base.astro";
import { translations } from "../../i18n/translations";
import type { Lang } from "../../i18n/translations";

export function getStaticPaths() {
  return [
    { params: { lang: "fa" } },
    { params: { lang: "ar" } },
    { params: { lang: "ckb" } },
    { params: { lang: "kmr" } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const tr = translations[lang];
const c = tr.contact;
---

<Base title={`${c.hero_label} — Yash`} description={c.hero_sub} lang={lang} slug="contact">
  <div class="container">
    <section class="hero">
      <p class="hero-label">{c.hero_label}</p>
      <h1 class="hero-headline">
        {c.hero_headline_1}<br />
        <em>{c.hero_headline_2}</em>
      </h1>
      <p class="hero-sub">{c.hero_sub}</p>
    </section>

    <section class="section">
      <span class="label">{c.reach_label}</span>
      <div class="contact-block">
        <div class="contact-line">
          <span class="contact-key">Email</span>
          <span class="contact-val"><a href="mailto:yashimosh@pm.me">yashimosh@pm.me</a></span>
        </div>
        <div class="contact-line">
          <span class="contact-key">Instagram</span>
          <span class="contact-val"><a href="https://instagram.com/yashimosh" target="_blank" rel="noopener">@yashimosh</a></span>
        </div>
        <div class="contact-line">
          <span class="contact-key">LinkedIn</span>
          <span class="contact-val"><a href="https://linkedin.com/in/yashimosh" target="_blank" rel="noopener">yashimosh</a></span>
        </div>
        <div class="contact-line">
          <span class="contact-key">Behance</span>
          <span class="contact-val"><a href="https://behance.net/yashimosh" target="_blank" rel="noopener">@yashimosh</a></span>
        </div>
        <div class="contact-line">
          <span class="contact-key">X</span>
          <span class="contact-val"><a href="https://x.com/yashimosh_" target="_blank" rel="noopener">@yashimosh_</a></span>
        </div>
      </div>
    </section>

    <section class="section">
      <span class="label">{c.before_label}</span>
      <h2>{c.before_title}</h2>
      <div class="bio-block">
        <p>{c.before_body}</p>
        <p>{c.before_body2}</p>
      </div>
    </section>
  </div>
</Base>
