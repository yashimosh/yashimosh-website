---
export interface Props {
  title: string;
  description: string;
  lang?: string;
  slug?: string;
}
const { title, description, lang = "en", slug = "" } = Astro.props;

const rtlLangs = ["fa", "ar", "ckb"];
const isRtl = rtlLangs.includes(lang);
const dir = isRtl ? "rtl" : "ltr";

const langNames: Record<string, string> = {
  en: "En", fa: "فا", ar: "عر", ckb: "کو", kmr: "Ku",
};

function pageUrl(targetLang: string, pageSlug: string): string {
  const base = targetLang === "en" ? "" : `/${targetLang}`;
  return base + (pageSlug ? `/${pageSlug}` : "/");
}

const currentPathname = Astro.url.pathname;

function isActive(pageSlug: string): boolean {
  if (pageSlug === "") {
    return currentPathname === "/" || currentPathname === `/${lang}` || currentPathname === `/${lang}/`;
  }
  return currentPathname.endsWith(`/${pageSlug}`) || currentPathname.endsWith(`/${pageSlug}/`);
}

const navLinks = [
  { slug: "",         labels: { en:"Home",     fa:"خانه",    ar:"الرئيسية", ckb:"ماڵ",      kmr:"Malper"   }},
  { slug: "about",    labels: { en:"About",    fa:"درباره",  ar:"نبذة",     ckb:"دەربارە",  kmr:"Derbarê"  }},
  { slug: "work",     labels: { en:"Work",     fa:"کار",     ar:"الأعمال",  ckb:"کار",      kmr:"Kar"      }},
  { slug: "thinking", labels: { en:"Thinking", fa:"دیدگاه‌ها", ar:"رؤى",   ckb:"بیرکردنەوە", kmr:"Ramanan" }},
  { slug: "contact",  labels: { en:"Contact",  fa:"تماس",    ar:"اتصل",    ckb:"پەیوەندی", kmr:"Têkilî"   }},
];

import "../styles/global.css";
---

<!DOCTYPE html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#080808" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <nav id="main-nav">
      <div class="nav-inner">
        <a href={pageUrl(lang, "")} class="nav-logo">Yash</a>

        <!-- desktop links -->
        <ul class="nav-links">
          {navLinks.map(({ slug: s, labels }) => (
            <li>
              <a href={pageUrl(lang, s)} class={isActive(s) ? "active" : ""}>
                {labels[lang as keyof typeof labels] ?? labels.en}
              </a>
            </li>
          ))}
        </ul>

        <!-- desktop lang switcher -->
        <div class="lang-switcher">
          {Object.entries(langNames).map(([code, label]) => (
            <a
              href={pageUrl(code, slug)}
              class={`lang-btn${lang === code ? " lang-active" : ""}`}
              aria-label={`Switch language to ${code}`}
            >{label}</a>
          ))}
        </div>

        <!-- hamburger button -->
        <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </nav>

    <!-- mobile menu -->
    <div class="nav-mobile" id="nav-mobile" aria-hidden="true">
      <nav class="nav-mobile-links">
        {navLinks.map(({ slug: s, labels }) => (
          <a href={pageUrl(lang, s)} class={isActive(s) ? "active" : ""}>
            {labels[lang as keyof typeof labels] ?? labels.en}
          </a>
        ))}
      </nav>
      <div class="nav-mobile-langs">
        {Object.entries(langNames).map(([code, label]) => (
          <a
            href={pageUrl(code, slug)}
            class={`lang-btn${lang === code ? " lang-active" : ""}`}
          >{label}</a>
        ))}
      </div>
    </div>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner container">
        <span class="footer-copy">© 2026 Yash.</span>
        <div class="footer-links">
          <a href="https://instagram.com/yashimosh" target="_blank" rel="noopener">Instagram</a>
          <a href="https://linkedin.com/in/yashimosh" target="_blank" rel="noopener">LinkedIn</a>
          <a href="https://behance.net/yashimosh" target="_blank" rel="noopener">Behance</a>
          <a href="https://x.com/yashimosh_" target="_blank" rel="noopener">X</a>
        </div>
      </div>
    </footer>

    <script>
      // ── nav scroll border
      const nav = document.getElementById('main-nav');
      window.addEventListener('scroll', () => {
        nav?.classList.toggle('scrolled', window.scrollY > 20);
      }, { passive: true });

      // ── hamburger toggle
      const btn = document.getElementById('nav-hamburger');
      const mob = document.getElementById('nav-mobile');
      btn?.addEventListener('click', () => {
        const open = btn.classList.toggle('open');
        mob?.classList.toggle('open', open);
        btn.setAttribute('aria-expanded', String(open));
        mob?.setAttribute('aria-hidden', String(!open));
        document.body.style.overflow = open ? 'hidden' : '';
      });
      // close mobile menu on link click
      mob?.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          btn?.classList.remove('open');
          mob?.classList.remove('open');
          btn?.setAttribute('aria-expanded', 'false');
          mob?.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        });
      });

      // ── scroll reveal
      const reveals = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        reveals.forEach(el => io.observe(el));
      } else {
        reveals.forEach(el => el.classList.add('visible'));
      }
    </script>
  </body>
</html>
